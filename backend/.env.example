# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ─── Database (Prisma) ────────────────────────────────────────────────────────
# Local: postgresql://postgres:postgres@localhost:5432/portfolio?schema=public
# Neon:  postgresql://user:pass@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio?schema=public

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-8-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-8-chars

# ─── Mail (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
MAIL_FROM=noreply@yourdomain.com

# ─── OAuth (Optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# ─── Cloudinary (Optional) ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
